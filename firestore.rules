rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // A user may read and write only documents under their own /users/{uid}
    // tree. uid must match the authenticated Firebase user.
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid} {
      // The user document itself is owner-only (if ever used).
      allow read, write: if isOwner(uid);

      // Reusable routine templates.
      match /routines/{routineId} {
        allow read, write: if isOwner(uid);
      }

      // Immutable historical workout sessions.
      match /workoutSessions/{sessionId} {
        allow read, write: if isOwner(uid);
      }

      // User preferences (single 'preferences' doc).
      match /settings/{settingId} {
        allow read, write: if isOwner(uid);
      }

      // User-owned custom exercises.
      match /customExercises/{exerciseId} {
        allow read, write: if isOwner(uid);
      }
    }
  }
}
